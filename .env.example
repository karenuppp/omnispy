# ============================================================
# omnispy configuration template
# Copy this file to `.env` and fill in real values.
# ============================================================

# ---- X (Twitter) ----
# Paste the full cookie string exported from your browser
# after logging into x.com. Format: "key=value; key=value; ..."
# Required keys typically include: auth_token, ct0, gt, etc.
X_COOKIE=

# ---- LLM (LM Studio, OpenAI-compatible local endpoint on :1234) ----
# Start LM Studio, load the model, and enable the local server (default :1234).
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=gemma-4-e4b
LLM_API_KEY=lmstudio

# ---- HTTP server ----
HTTP_HOST=127.0.0.1
HTTP_PORT=8000