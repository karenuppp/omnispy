# ============================================================
# omnispy configuration template
# Copy this file to `.env` and fill in real values.
# ============================================================

# ---- X (Twitter) ----
# Paste the full cookie string exported from your browser
# after logging into x.com. Format: "key=value; key=value; ..."
# Required keys typically include: auth_token, ct0, gt, etc.
X_COOKIE=

# ---- LLM (Ollama, OpenAI-compatible local endpoint) ----
# Make sure `ollama serve` is running before starting omnispy.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_API_KEY=ollama

# ---- HTTP server ----
HTTP_HOST=127.0.0.1
HTTP_PORT=8000